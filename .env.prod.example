MYSQL_PASSWORD=wine_secure_password

# Authentication (CHANGE THESE FOR PRODUCTION)
JWT_TOKEN_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET_FOR_PROD
JWT_TOKEN_EXPIRED=24h

# Logging
MORGAN_ENVIRONMENT=combined
LOG_LEVEL=info
