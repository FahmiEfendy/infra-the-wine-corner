# Server Configuration
PORT=5001
NODE_ENV=production

# Database Configuration
DB_HOST=db
DB_USER=wine_user
DB_PASSWORD=wine_secure_password
DB_NAME=the_wine_corner_prod

# Docker MySQL Initialization
MYSQL_ROOT_PASSWORD=root_secure_password
